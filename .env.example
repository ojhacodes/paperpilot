# PaperPilot Environment Variables
# Rename this file to '.env' and populate the credentials below.

# LLM Provider API Keys (Provide at least one of these)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Default LLM Provider (Choose from: gemini, openai, anthropic)
DEFAULT_PROVIDER=gemini
